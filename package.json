{
	"name": "zget-cli",
	"version": "0.1.0",
	"description": "Download Zhihu articles, answers, videos, and columns to Markdown",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/AstroAir/zget-cli.git"
	},
	"homepage": "https://github.com/AstroAir/zget-cli#readme",
	"bugs": {
		"url": "https://github.com/AstroAir/zget-cli/issues"
	},
	"keywords": [
		"cli",
		"markdown",
		"zhihu",
		"bilibili",
		"xiaohongshu",
		"twitter"
	],
	"bin": "dist/cli.js",
	"type": "module",
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org"
	},
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "esbuild source/cli.tsx --bundle --platform=node --format=esm --target=node20 --outfile=dist/cli.js --sourcemap --jsx=automatic --external:ink --external:react --external:@inkjs/ui --external:qrcode --external:cheerio --external:turndown --external:sanitize-filename --external:undici --external:meow --external:playwright --external:dotenv",
		"build:check": "tsc --noEmit",
		"ci:local": "pnpm test && pnpm test:components && pnpm test:core && pnpm test:commands && pnpm test:docs && pnpm docs:check && pnpm build:check && pnpm build && pnpm smoke && pnpm pack:check",
		"dev": "tsx source/cli.tsx",
		"docs:generate": "tsx tools/docs/generate-docs.ts",
		"docs:check": "tsx tools/docs/check-generated-docs.ts",
		"lint:staged": "lint-staged --concurrent false",
		"lint": "xo",
		"pack:check": "node --input-type=module -e \"import {mkdirSync, rmSync} from 'node:fs'; rmSync('.pack-check', {recursive: true, force: true}); mkdirSync('.pack-check', {recursive: true});\" && pnpm pack --pack-destination .pack-check && node --input-type=module -e \"import {readdirSync, rmSync} from 'node:fs'; const files = readdirSync('.pack-check').filter(file => file.endsWith('.tgz')).sort(); if (files.length === 0) { console.error('[release] pnpm pack did not create any .tgz artifact.'); process.exit(1); } console.log('[release] Pack artifact created: ' + files[0]); rmSync('.pack-check', {recursive: true, force: true});\"",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"prepare": "simple-git-hooks",
		"prepublishOnly": "pnpm release:verify",
		"release:assert-version": "tsx tools/release/assert-release-version.ts",
		"release:npm": "pnpm release:verify && pnpm publish --no-git-checks",
		"release:npm:dry-run": "pnpm release:verify && pnpm publish --dry-run --no-git-checks",
		"release:verify": "pnpm verify:ci",
		"smoke": "node dist/cli.js --help",
		"test": "prettier --check . && xo",
		"test:commands": "vitest run --pool threads --config vitest.commands.config.mjs",
		"test:commands:coverage": "vitest run --pool threads --config vitest.commands.config.mjs --coverage.enabled",
		"test:components": "vitest run --pool threads --config vitest.components.config.ts",
		"test:components:coverage": "vitest run --pool threads --config vitest.components.config.ts --coverage.enabled",
		"test:core": "vitest run --pool threads --config vitest.core.config.ts",
		"test:core:coverage": "vitest run --pool threads --config vitest.core.config.ts --coverage.enabled",
		"test:docs": "vitest run --pool threads --config vitest.config.ts",
		"test:docs:coverage": "vitest run --pool threads --config vitest.config.ts --coverage.enabled",
		"verify:ci": "pnpm test && pnpm test:components:coverage && pnpm test:core:coverage && pnpm test:commands:coverage && pnpm test:docs:coverage && pnpm docs:check && pnpm build:check && pnpm build && pnpm smoke && pnpm pack:check"
	},
	"files": [
		"dist"
	],
	"dependencies": {
		"@inkjs/ui": "^2.0.0",
		"cheerio": "^1.2.0",
		"dotenv": "^16.6.1",
		"ink": "^6.8.0",
		"meow": "^11.0.0",
		"playwright": "^1.60.0",
		"qrcode": "^1.5.4",
		"react": "^19.2.6",
		"sanitize-filename": "^1.6.4",
		"turndown": "^7.2.4",
		"undici": "^7.25.0"
	},
	"devDependencies": {
		"@sindresorhus/tsconfig": "^3.0.1",
		"@types/ink-testing-library": "1.0.4",
		"@types/node": "^20.19.41",
		"@types/react": "^19.2.14",
		"@types/sanitize-filename": "^1.6.3",
		"@types/turndown": "^5.0.6",
		"@vdemedes/prettier-config": "^2.0.1",
		"@vitest/coverage-v8": "4.1.0",
		"chalk": "^5.6.2",
		"esbuild": "0.27.4",
		"eslint": "^8.57.1",
		"eslint-config-xo-react": "^0.27.0",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^4.6.2",
		"ink-testing-library": "4.0.0",
		"lint-staged": "^16.4.0",
		"prettier": "^2.8.8",
		"simple-git-hooks": "^2.13.1",
		"tsx": "4.21.0",
		"typedoc": "0.28.17",
		"typedoc-plugin-markdown": "4.10.0",
		"typescript": "^5.9.3",
		"vitest": "4.1.0",
		"xo": "^0.53.1"
	},
	"xo": {
		"extends": "xo-react",
		"prettier": true,
		"semicolon": true,
		"parserOptions": {
			"project": "./tsconfig.xo.json"
		},
		"overrides": [
			{
				"files": [
					"source/cli.tsx"
				],
				"rules": {
					"@typescript-eslint/no-unsafe-call": "off",
					"unicorn/no-process-exit": "off"
				}
			},
			{
				"files": [
					"tools/**/*.ts",
					"tests/**/*.ts",
					"tests/**/*.tsx",
					"vitest*.config.ts"
				],
				"parserOptions": {
					"project": "./tsconfig.tools.json"
				},
				"rules": {
					"import/extensions": "off",
					"n/file-extension-in-import": "off"
				}
			},
			{
				"files": [
					"tools/**/*.ts"
				],
				"rules": {
					"@typescript-eslint/no-unsafe-assignment": "off",
					"@typescript-eslint/no-unsafe-call": "off",
					"@typescript-eslint/no-unsafe-return": "off",
					"@typescript-eslint/restrict-template-expressions": "off"
				}
			},
			{
				"files": [
					"tests/**/*.ts",
					"tests/**/*.tsx"
				],
				"rules": {
					"@typescript-eslint/naming-convention": "off",
					"@typescript-eslint/ban-types": "off",
					"@typescript-eslint/no-unsafe-assignment": "off",
					"@typescript-eslint/no-unsafe-call": "off",
					"@typescript-eslint/no-unsafe-return": "off",
					"@typescript-eslint/restrict-template-expressions": "off",
					"import/first": "off"
				}
			},
			{
				"files": [
					"tests/source/commands/**/*.tsx"
				],
				"rules": {
					"@typescript-eslint/no-empty-function": "off",
					"@typescript-eslint/no-extraneous-class": "off",
					"@typescript-eslint/promise-function-async": "off",
					"no-constructor-return": "off"
				}
			},
			{
				"files": [
					"source/core/api/weibo-api.ts",
					"source/core/api/weibo-image-upload.ts",
					"source/core/auth/weibo-auth.ts",
					"source/core/parser/platforms/weibo-parser.ts",
					"source/types/weibo.ts"
				],
				"rules": {
					"@typescript-eslint/naming-convention": "off",
					"@typescript-eslint/restrict-template-expressions": "off",
					"complexity": "off",
					"no-await-in-loop": "off",
					"unicorn/better-regex": "off",
					"unicorn/explicit-length-check": "off",
					"@typescript-eslint/no-implicit-any-catch": "off",
					"@typescript-eslint/consistent-type-assertions": "off",
					"@typescript-eslint/no-unnecessary-type-assertion": "off",
					"@typescript-eslint/no-unsafe-assignment": "off",
					"@typescript-eslint/prefer-nullish-coalescing": "off",
					"prefer-destructuring": "off"
				}
			},
			{
				"files": [
					"source/commands/weibo-*.tsx"
				],
				"rules": {
					"@typescript-eslint/naming-convention": "off",
					"unicorn/prefer-default-parameters": "off"
				}
			},
			{
				"files": [
					"source/core/utils/url-parser.ts"
				],
				"rules": {
					"complexity": "off",
					"unicorn/better-regex": "off"
				}
			},
			{
				"files": [
					"source/core/downloader/platforms/weibo-downloader.ts"
				],
				"rules": {
					"@typescript-eslint/naming-convention": "off",
					"@typescript-eslint/prefer-nullish-coalescing": "off"
				}
			}
		],
		"rules": {
			"import/extensions": "off",
			"n/file-extension-in-import": "off",
			"react/prop-types": "off",
			"react/react-in-jsx-scope": "off",
			"react/jsx-uses-react": "off",
			"unicorn/expiring-todo-comments": "off"
		}
	},
	"simple-git-hooks": {
		"commit-msg": "node tools/git-hooks/commit-msg-check.mjs \"$1\"",
		"pre-commit": "pnpm lint:staged",
		"pre-push": "pnpm ci:local"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,mjs,cjs}": [
			"xo"
		],
		"*.{json,md,yml,yaml}": [
			"prettier --check"
		]
	},
	"pnpm": {
		"overrides": {
			"xo>typescript": "5.9.3"
		}
	},
	"prettier": "@vdemedes/prettier-config"
}
